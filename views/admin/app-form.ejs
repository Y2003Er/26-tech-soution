<%- include('../partials/head', { title: (app ? 'Edit App' : 'New Upload') + ' - 26 Tech Admin' }) %>
<%- include('../partials/admin-nav') %>
<main class="admin-main">
  <header class="admin-topbar"><div><span class="eyebrow">Upload manager</span><h1><%= app ? 'Edit Software' : 'New Software Upload' %></h1></div><a href="/admin" class="btn btn-secondary">Back</a></header>
  <% if (error && error.length > 0) { %><div class="flash error"><%= error %></div><% } %>
  <form class="upload-form" method="POST" enctype="multipart/form-data" action="<%= app ? '/admin/apps/' + app.id + '/edit' : '/admin/apps' %>">
    <section class="upload-drop"><input type="file" name="icon" accept="image/*"><div><strong>Drag and drop app icon</strong><span>or click to choose a new image</span></div><% if (app && app.icon_file_id) { %><img src="/icon/<%= app.icon_file_id %>" alt="Current icon"><% } %></section>
    <section class="form-grid"><label>App Name *<input type="text" name="name" value="<%= app ? app.name : '' %>" required data-slug-source></label><label>Category *<input type="text" name="category" placeholder="Android, Windows, Games..." value="<%= app ? app.category : '' %>" required></label><label class="full">Slug Preview<input type="text" value="<%= app ? app.slug : '' %>" readonly data-slug-preview></label><label class="full">Description *<textarea name="description" required><%= app ? app.description : '' %></textarea></label><label class="full">Download URL / Telegram File ID *<input type="text" name="download_url" value="<%= app ? app.download_url : '' %>" required></label><label class="full">App Icon Telegram File ID<input type="text" name="icon_file_id" value="<%= app && app.icon_file_id ? app.icon_file_id : '' %>"></label><label>Version<input type="text" name="version" value="<%= app ? app.version : 'v1.0' %>"></label><label>File Size<input type="text" name="file_size" placeholder="45 MB" value="<%= app ? app.file_size : '' %>"></label><label>Platform<select name="os"><% ['Windows','Android','macOS','iOS','Linux','Multi'].forEach(os => { %><option value="<%= os %>" <%= app && app.os === os ? 'selected' : '' %>><%= os %></option><% }) %></select></label><label>Type<select name="is_free"><option value="true" <%= !app || app.is_free ? 'selected' : '' %>>Free</option><option value="false" <%= app && !app.is_free ? 'selected' : '' %>>Premium</option></select></label><label>Featured Toggle<select name="is_featured"><option value="false" <%= !app || !app.is_featured ? 'selected' : '' %>>No</option><option value="true" <%= app && app.is_featured ? 'selected' : '' %>>Yes</option></select></label><label>Trending Toggle<select disabled><option>Auto by downloads</option></select></label><label>Popular Toggle<select disabled><option>Auto by views</option></select></label><label>Auto Timestamp<input type="text" value="Managed by database" readonly></label><label class="full">Version History<textarea placeholder="Optional release notes for the changelog layout"></textarea></label><label class="full">SEO Fields<textarea placeholder="Meta title, keywords, and search notes"></textarea></label><% if (app) { %><label>Status<select name="is_active"><option value="true" <%= app.is_active ? 'selected' : '' %>>Active</option><option value="false" <%= !app.is_active ? 'selected' : '' %>>Hidden</option></select></label><% } %></section>
    <div class="upload-progress"><span></span></div><div class="form-actions"><button class="btn btn-primary" type="submit"><%= app ? 'Save Changes' : 'Publish Software' %></button><a href="/admin" class="btn btn-secondary">Cancel</a></div>
  </form>
</main>
<%- include('../partials/foot') %>