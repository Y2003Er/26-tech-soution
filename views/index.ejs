<%- include('partials/head', { title: '26 Tech Solution - Software Hub' }) %>

<style>
  /* ── Global Reset ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Inter', system-ui, sans-serif; background: #0a0a0f; color: #e2e2e8; }

  /* ── Header ── */
  .hdr {
    position: sticky; top: 0; z-index: 100;
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    height: 64px; display: flex; align-items: center;
    padding: 0 1.5rem; gap: 1rem;
  }
  .hdr-logo {
    font-size: 1.2rem; font-weight: 800;
    color: #fff; letter-spacing: -0.5px; white-space: nowrap;
  }
  .hdr-logo span { color: #6366f1; }
  .hdr-nav { display: flex; gap: 4px; margin-left: 1.5rem; }
  .hdr-nav a {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: 8px;
    font-size: 13px; font-weight: 500; color: #8a8a98;
    transition: all 0.2s ease;
  }
  .hdr-nav a:hover { background: rgba(255,255,255,0.05); color: #fff; }
  .hdr-nav a.active { color: #6366f1; background: rgba(99,102,241,0.1); }
  .hdr-nav a svg { width: 16px; height: 16px; flex-shrink: 0; }

  .hdr-search-form {
    margin-left: auto; display: flex; align-items: center;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 9999px;
    padding: 0 14px; gap: 8px; height: 40px; min-width: 200px;
    transition: all 0.2s ease;
  }
  .hdr-search-form:focus-within {
    border-color: #6366f1;
    background: rgba(255,255,255,0.08);
  }
  .hdr-search-form input {
    border: none; background: transparent; outline: none;
    font-size: 13px; color: #fff; width: 100%;
  }
  .hdr-search-form input::placeholder { color: #55555f; }
  .hdr-search-form svg { width: 16px; height: 16px; color: #55555f; }

  /* ── Mobile Menu ── */
  .hdr-menu-btn {
    display: none; border: none; background: none;
    width: 36px; height: 36px; border-radius: 50%;
    align-items: center; justify-content: center; cursor: pointer;
    color: #8a8a98;
  }
  @media (max-width: 640px) {
    .hdr-menu-btn { display: flex; }
    .hdr-nav { display: none; }
    .hdr-search-form { min-width: 0; flex: 1; }
  }

  /* ── Page ── */
  .page { max-width: 1200px; margin: 0 auto; padding: 1.5rem 1rem 3rem; }

  /* ── Section Headers ── */
  .sec-hdr {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 1rem;
  }
  .sec-hdr-icon { width: 20px; height: 20px; color: #6366f1; flex-shrink: 0; }
  .sec-hdr-title {
    font-size: 15px; font-weight: 700; color: #fff;
  }
  .sec-hdr-more {
    margin-left: auto; font-size: 12px; font-weight: 600;
    color: #6366f1; cursor: pointer;
  }

  /* ── Featured Scroll ── */
  .feat-scroll {
    display: flex; gap: 14px;
    overflow-x: auto; padding-bottom: 8px;
    scrollbar-width: none; -webkit-overflow-scrolling: touch;
  }
  .feat-scroll::-webkit-scrollbar { display: none; }

  .feat-card {
    flex: 0 0 260px; border-radius: 14px; overflow: hidden;
    background: #1a1a24; border: 1px solid rgba(255,255,255,0.06);
    transition: all 0.3s ease; cursor: pointer;
  }
  .feat-card:hover {
    transform: translateY(-4px);
    border-color: #6366f1;
    box-shadow: 0 12px 40px rgba(0,0,0,0.5);
  }
  .feat-card-thumb {
    width: 100%; aspect-ratio: 16/9;
    display: flex; align-items: center; justify-content: center;
    font-size: 48px; color: #fff;
  }
  .feat-card-info {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px; background: #1a1a24;
    border-top: 1px solid rgba(255,255,255,0.04);
  }
  .feat-card-ico {
    width: 38px; height: 38px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; background: rgba(255,255,255,0.06);
    flex-shrink: 0;
  }
  .feat-card-name { font-size: 13px; font-weight: 600; color: #fff; }
  .feat-card-cat { font-size: 11px; color: #6366f1; font-weight: 600; }

  /* ── Collections Grid ── */
  .coll-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  @media (min-width: 640px) { .coll-grid { grid-template-columns: repeat(4, 1fr); } }

  .coll-card {
    border-radius: 14px; overflow: hidden;
    position: relative; aspect-ratio: 1; cursor: pointer;
    background: #1a1a2e;
  }
  .coll-card-bg {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    transition: transform 0.4s ease;
  }
  .coll-card:hover .coll-card-bg { transform: scale(1.06); }
  .coll-ov {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 55%, transparent 100%);
  }
  .coll-body {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 12px;
  }
  .coll-title {
    color: #fff; font-size: 13px; font-weight: 700;
    margin-bottom: 6px;
  }
  .coll-icons { display: flex; gap: 4px; flex-wrap: wrap; align-items: flex-end; }
  .coll-ico {
    width: 32px; height: 32px; border-radius: 8px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; flex-shrink: 0;
  }
  .coll-more { color: #fff; font-size: 12px; font-weight: 700; }

  /* ── Tab Bar ── */
  .tab-bar {
    display: flex; gap: 4px; overflow-x: auto;
    scrollbar-width: none; padding: 4px;
    margin-bottom: 1rem;
    background: #1a1a24;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
  }
  .tab-bar::-webkit-scrollbar { display: none; }
  .tab-bar a {
    padding: 6px 14px; border-radius: 7px;
    font-size: 12px; font-weight: 600;
    white-space: nowrap; color: #8a8a98;
    transition: all 0.15s ease;
  }
  .tab-bar a:hover { color: #fff; }
  .tab-bar a.active {
    background: #6366f1; color: #fff;
  }

  /* ── App Grid ── */
  .app-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
  @media (min-width: 480px) { .app-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 720px) { .app-grid { grid-template-columns: repeat(4, 1fr); } }

  .app-card {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px; border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.06);
    background: #1a1a24;
    cursor: pointer; transition: all 0.2s ease;
  }
  .app-card:hover {
    background: rgba(255,255,255,0.04);
    border-color: #6366f1;
  }
  .app-card-ico {
    width: 44px; height: 44px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; flex-shrink: 0;
    background: rgba(255,255,255,0.06);
  }
  .app-card-name { font-size: 12px; font-weight: 600; color: #fff; }
  .app-card-cat { font-size: 11px; color: #8a8a98; margin-top: 2px; }
  .app-badge {
    display: inline-block; font-size: 9px; font-weight: 700;
    padding: 2px 6px; border-radius: 4px; margin-top: 4px;
    text-transform: uppercase; letter-spacing: 0.3px;
  }
  .badge-free { background: rgba(0,255,136,0.12); color: #00ff88; }
  .badge-premium { background: rgba(245,158,11,0.12); color: #f59e0b; }

  /* ── Pagination ── */
  .pager { display: flex; gap: 6px; justify-content: center; margin-top: 2rem; flex-wrap: wrap; }
  .pager a {
    padding: 6px 14px; border-radius: 8px;
    font-size: 13px; font-weight: 600;
    border: 1px solid rgba(255,255,255,0.06);
    background: #1a1a24; color: #8a8a98;
    transition: all 0.15s ease;
  }
  .pager a:hover { border-color: #6366f1; color: #fff; }
  .pager a.active { background: #6366f1; border-color: #6366f1; color: #fff; }

  .section { margin-top: 2rem; }
  .empty-state { text-align: center; padding: 3rem; color: #55555f; font-size: 14px; }

  /* ── Mobile Bottom Nav ── */
  .mobile-tabbar { display: none; }
  @media (max-width: 600px) {
    .mobile-tabbar {
      display: flex; position: fixed; bottom: 0; left: 0; right: 0; z-index: 300;
      background: rgba(17,17,24,0.95); backdrop-filter: blur(16px);
      border-top: 1px solid rgba(255,255,255,0.06);
      padding: 6px 0;
    }
    .mobile-tabbar a {
      flex: 1; display: flex; flex-direction: column; align-items: center; gap: 2px;
      font-size: 10px; font-weight: 600; color: #8a8a98; padding: 4px 0;
    }
    .mobile-tabbar a svg { width: 20px; height: 20px; }
    .mobile-tabbar a.active { color: #6366f1; }
    body { padding-bottom: 60px; }
  }
</style>

<%
  const featuredApps = apps.filter(a => a.is_featured).slice(0, 6);
  const catIcons = {
    Design: 'D', Office: 'O', Games: 'G',
    Security: 'S', Android: 'A', Windows: 'W', macOS: 'M'
  };
  const catColors = {
    Design: '#1a237e', Office: '#1b5e20', Games: '#b71c1c',
    Security: '#004d40', Android: '#4a148c', Windows: '#0d47a1', macOS: '#212121'
  };
%>

<!-- ════════════════════════════════════
     HEADER
════════════════════════════════════ -->
<header class="hdr">
  <button class="hdr-menu-btn" aria-label="Menu">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
      <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/>
    </svg>
  </button>

  <a href="/" class="hdr-logo"><span>26</span>Tech</a>

  <nav class="hdr-nav">
    <a href="/" class="<%= currentCat === 'Zote' && !query ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
      Nyumbani
    </a>
    <a href="/?cat=Android" class="<%= currentCat === 'Android' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.6 11.8c0-3.1-1.9-5.8-4.6-7l.8-1.6c.1-.2 0-.4-.2-.5-.2-.1-.4 0-.5.2l-.8 1.6C11.5 4.2 10.8 4 10 4s-1.5.2-2.3.5l-.8-1.6c-.1-.2-.3-.3-.5-.2-.2.1-.3.3-.2.5l.8 1.6c-2.7 1.2-4.6 3.9-4.6 7H17.6zM7.5 10c-.6 0-1-.4-1-1s.4-1 1-1 1 .4 1 1-.4 1-1 1zm5 0c-.6 0-1-.4-1-1s.4-1 1-1 1 .4 1 1-.4 1-1 1zM2.4 12.8c0 2.8 1.5 5.2 3.8 6.6l-.8 1.3c-.1.2 0 .4.1.5.2.1.4 0 .5-.1l.8-1.3c1 .5 2 .7 3.2.7s2.2-.3 3.2-.7l.8 1.3c.1.2.3.2.5.1.2-.1.2-.4.1-.5l-.8-1.3c2.3-1.4 3.8-3.8 3.8-6.6H2.4z"/></svg>
      Apps
    </a>
    <a href="/?cat=Games" class="<%= currentCat === 'Games' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5S14.67 12 15.5 12s1.5.67 1.5 1.5S16.33 15 15.5 15zm3-3c-.83 0-1.5-.67-1.5-1.5S17.67 9 18.5 9s1.5.67 1.5 1.5S19.33 12 18.5 12z"/></svg>
      Games
    </a>
    <a href="/?cat=Windows">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
      Windows
    </a>
    <a href="/?cat=Design">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.49 2 2 6.49 2 12s4.49 10 10 10c1.38 0 2.5-1.12 2.5-2.5 0-.61-.23-1.17-.6-1.59-.37-.41-.59-.96-.59-1.51 0-1.38 1.12-2.5 2.5-2.5H16c2.76 0 5-2.24 5-5 0-4.42-4.03-8-9-8zm-5.5 9c-.83 0-1.5-.67-1.5-1.5S5.67 8 6.5 8 8 8.67 8 9.5 7.33 11 6.5 11zm3-4C8.67 7 8 6.33 8 5.5S8.67 4 9.5 4s1.5.67 1.5 1.5S10.33 7 9.5 7zm5 0c-.83 0-1.5-.67-1.5-1.5S13.67 4 14.5 4s1.5.67 1.5 1.5S15.33 7 14.5 7zm3 4c-.83 0-1.5-.67-1.5-1.5S16.67 8 17.5 8s1.5.67 1.5 1.5S18.33 11 17.5 11z"/></svg>
      Design
    </a>
  </nav>

  <form class="hdr-search-form" action="/" method="GET">
    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
    <input type="search" name="q" placeholder="Tafuta software..." value="<%= typeof query !== 'undefined' ? query : '' %>"/>
  </form>
</header>


<!-- ════════════════════════════════════
     PAGE BODY
════════════════════════════════════ -->
<div class="page">

  <!-- ── 1. FEATURED ── -->
  <% if (featuredApps.length > 0) { %>
  <div class="sec-hdr">
    <svg class="sec-hdr-icon" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
    </svg>
    <span class="sec-hdr-title">Featured Apps</span>
  </div>
  <div class="feat-scroll">
    <% featuredApps.forEach(app => { %>
    <a href="/app/<%= app.slug %>" class="feat-card">
      <div class="feat-card-thumb" style="background: <%= catColors[app.category] || '#1a1a2e' %>">
        <%= app.icon || '📱' %>
      </div>
      <div class="feat-card-info">
        <div class="feat-card-ico"><%= app.icon || '📱' %></div>
        <div>
          <div class="feat-card-name"><%= app.name %></div>
          <div class="feat-card-cat"><%= app.category %></div>
        </div>
      </div>
    </a>
    <% }) %>
  </div>
  <% } %>

  <!-- ── 2. CATEGORIES ── -->
  <% if (categories.length > 0) { %>
  <div class="section">
    <div class="sec-hdr">
      <svg class="sec-hdr-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M4 6h16v2H4V6zm0 5h16v2H4v-2zm0 5h10v2H4v-2z"/>
      </svg>
      <span class="sec-hdr-title">Browse by Category</span>
    </div>
    <div class="coll-grid">
      <% categories.slice(0, 4).forEach(c => {
          const color = catColors[c.category] || '#1a1a2e';
          const icon = catIcons[c.category] || '📦';
          const catApps = apps.filter(a => a.category === c.category).slice(0, 3);
      %>
      <a href="/?cat=<%= encodeURIComponent(c.category) %>" class="coll-card">
        <div class="coll-card-bg" style="background: linear-gradient(135deg, <%= color %>, <%= color %>cc)"></div>
        <div class="coll-ov"></div>
        <div class="coll-body">
          <div class="coll-title"><%= c.category %></div>
          <div class="coll-icons">
            <% catApps.forEach(a => { %>
              <div class="coll-ico"><%= a.icon || '📱' %></div>
            <% }) %>
            <% if (c.total > 3) { %>
              <span class="coll-more">+<%= c.total - 3 %></span>
            <% } %>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- ── 3. APP GRID ── -->
  <div class="section">
    <div class="sec-hdr">
      <svg class="sec-hdr-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6h-6z"/>
      </svg>
      <span class="sec-hdr-title">
        <%= currentCat !== 'Zote' ? currentCat : 'Trending Now' %>
      </span>
      <% if (totalPages > 1) { %>
        <span class="sec-hdr-more">Page <%= currentPage %> / <%= totalPages %></span>
      <% } %>
    </div>

    <div class="tab-bar">
      <a href="/" class="<%= currentCat === 'Zote' && !query ? 'active' : '' %>">Zote</a>
      <% categories.forEach(c => { %>
        <a href="/?cat=<%= encodeURIComponent(c.category) %>"
           class="<%= currentCat === c.category ? 'active' : '' %>">
          <%= catIcons[c.category] || '' %> <%= c.category %>
        </a>
      <% }) %>
    </div>

    <% if (apps.length === 0) { %>
      <div class="empty-state">Hakuna software iliyopatikana.</div>
    <% } else { %>
    <div class="app-grid">
      <% apps.forEach(app => { %>
      <a href="/app/<%= app.slug %>" class="app-card">
        <div class="app-card-ico"><%= app.icon || '📱' %></div>
        <div>
          <div class="app-card-name"><%= app.name %></div>
          <div class="app-card-cat"><%= app.category %></div>
          <% if (app.is_free) { %>
            <span class="app-badge badge-free">Bure</span>
          <% } else { %>
            <span class="app-badge badge-premium">Premium</span>
          <% } %>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>

    <% if (totalPages > 1) { %>
    <div class="pager">
      <% if (currentPage > 1) { %>
        <a href="/?cat=<%= currentCat %>&q=<%= query %>&page=<%= currentPage - 1 %>">← Iliyopita</a>
      <% } %>
      <% for (let p = Math.max(1, currentPage - 2); p <= Math.min(totalPages, currentPage + 2); p++) { %>
        <a href="/?cat=<%= currentCat %>&q=<%= query %>&page=<%= p %>"
           class="<%= p === currentPage ? 'active' : '' %>"><%= p %></a>
      <% } %>
      <% if (currentPage < totalPages) { %>
        <a href="/?cat=<%= currentCat %>&q=<%= query %>&page=<%= currentPage + 1 %>">Inayofuata →</a>
      <% } %>
    </div>
    <% } %>

  </div>
</div>

<%- include('partials/footer') %>
<%- include('partials/foot') %>