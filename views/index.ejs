<%- include('partials/head', { title: '26 TECH - Premium Software Downloads' }) %>
<%- include('partials/nav') %>
<%
const fmt = n => Number(n || 0).toLocaleString();
const dateFmt = d => d ? new Date(d).toLocaleDateString('en', { month: 'short', day: 'numeric', year: 'numeric' }) : 'Recently';
const allApps = apps || [];
const s = sections || { featured: [], trending: [], popular: [], latest: [], updated: [], recommended: [] };
const featured = s.featured.length ? s.featured : allApps.slice(0, 8);
const trending = s.trending.length ? s.trending : allApps.slice(0, 8);
const popular = s.popular.length ? s.popular : allApps.slice(0, 12);
const latest = s.latest.length ? s.latest : allApps.slice(0, 8);
const updated = s.updated.length ? s.updated : allApps.slice(0, 8);
const recommended = s.recommended.length ? s.recommended : allApps.slice(0, 6);
const catFallback = ['Android','Windows','Games','Design','Tools','Utilities'];
const shownCategories = categories.length ? categories : catFallback.map(category => ({ category, total: 0 }));
%>
<main>
  <section class="hero-shell">
    <div class="hero-content">
      <div class="eyebrow">Verified marketplace</div>
      <h1>Download Premium Software Faster.</h1>
      <p>Thousands of verified apps, games, software and tools, arranged for fast discovery and secure downloads.</p>
      <form class="hero-search" action="/" method="GET" data-search-form>
        <input type="search" name="q" value="<%= query || '' %>" placeholder="Search software, apps, games, utilities..." data-instant-search>
        <button type="submit">Search</button>
      </form>
      <div class="tag-row"><a href="/?q=editing">Editing</a><a href="/?cat=Android">Android</a><a href="/?cat=Windows">Windows</a><a href="/?cat=Games">Games</a><a href="/?sort=downloads">Top Downloads</a></div>
    </div>
    <div class="hero-showcase">
      <% featured.slice(0,3).forEach((app, i) => { %>
        <a class="showcase-card <%= i === 0 ? 'is-main' : '' %>" href="/app/<%= app.slug %>">
          <div class="app-icon"><% if (app.icon_file_id) { %><img src="/icon/<%= app.icon_file_id %>" alt=""><% } else { %><%- include('partials/app-icon', { category: app.category }) %><% } %></div>
          <div><strong><%= app.name %></strong><span><%= app.category %> - <%= fmt(app.downloads) %> downloads</span></div>
        </a>
      <% }) %>
    </div>
  </section>
  <section class="section" id="featured"><div class="section-head"><div><span>Featured Software</span><h2>Editor picks</h2></div><a href="/?sort=popular">View all</a></div><div class="carousel-row"><% featured.forEach(app => { %><a class="feature-card" href="/app/<%= app.slug %>"><div class="app-icon lg"><% if (app.icon_file_id) { %><img src="/icon/<%= app.icon_file_id %>" alt=""><% } else { %><%- include('partials/app-icon', { category: app.category }) %><% } %></div><div><h3><%= app.name %></h3><p><%= app.description || 'Verified software ready for download.' %></p><span><%= app.version || 'v1.0' %> - <%= app.file_size || 'N/A' %></span></div></a><% }) %></div></section>
  <section class="section" id="trending"><div class="section-head"><div><span>Trending Downloads</span><h2>Moving fast</h2></div></div><div class="trend-list"><% trending.forEach(app => { %><article class="trend-card"><a href="/app/<%= app.slug %>" class="trend-main"><div class="app-icon"><% if (app.icon_file_id) { %><img src="/icon/<%= app.icon_file_id %>" alt=""><% } else { %><%- include('partials/app-icon', { category: app.category }) %><% } %></div><div><h3><%= app.name %></h3><p><%= app.category %> - Rating 4.<%= (app.id || 7) % 9 %> - <%= fmt(app.downloads) %> downloads - <%= app.version || 'v1.0' %></p></div></a><button class="btn btn-primary" data-download-url="/go/<%= app.slug %>" data-download-name="<%= app.name %>">Download</button></article><% }) %></div></section>
  <section class="section" id="popular"><div class="section-head"><div><span>Popular Software</span><h2>Community favorites</h2></div></div><div class="software-grid"><% popular.forEach(app => { %><a class="software-card" href="/app/<%= app.slug %>"><div class="card-top"><div class="app-icon"><% if (app.icon_file_id) { %><img src="/icon/<%= app.icon_file_id %>" alt=""><% } else { %><%- include('partials/app-icon', { category: app.category }) %><% } %></div><span><%= app.is_free ? 'Free' : 'Premium' %></span></div><h3><%= app.name %></h3><p><%= app.category %> - <%= app.os || 'Multi' %></p><div class="metric-row"><span><%= fmt(app.downloads) %> downloads</span><span><%= app.file_size || 'N/A' %></span></div></a><% }) %></div></section>
  <section class="section split-section"><div id="latest"><div class="section-head compact"><div><span>Latest Uploads</span><h2>Fresh files</h2></div></div><div class="mini-list"><% latest.forEach(app => { %><a href="/app/<%= app.slug %>"><strong><%= app.name %></strong><span><%= dateFmt(app.created_at) %></span></a><% }) %></div></div><div id="updated"><div class="section-head compact"><div><span>Recently Updated</span><h2>New versions</h2></div></div><div class="mini-list"><% updated.forEach(app => { %><a href="/app/<%= app.slug %>"><strong><%= app.name %></strong><span><%= app.version || 'Latest' %> - <%= dateFmt(app.updated_at || app.created_at) %></span></a><% }) %></div></div></section>
  <section class="section" id="categories"><div class="section-head"><div><span>Categories</span><h2>Browse by platform</h2></div></div><div class="category-grid"><% shownCategories.slice(0,6).forEach(c => { %><a class="category-card" href="/?cat=<%= encodeURIComponent(c.category) %>"><span><%= c.category.slice(0,2).toUpperCase() %></span><h3><%= c.category %></h3><p><%= c.total || 0 %> apps</p></a><% }) %></div></section>
  <section class="section recommendation"><div><span>Recommended Software</span><h2>Smart picks based on momentum</h2><p>Downloads, views, and featured status are blended to surface strong options without changing your backend.</p></div><div class="recommend-grid"><% recommended.forEach(app => { %><a href="/app/<%= app.slug %>"><strong><%= app.name %></strong><span><%= app.category %> - <%= fmt((app.downloads || 0) + (app.views || 0)) %> signals</span></a><% }) %></div></section>
  <section class="section directory"><div class="section-head"><div><span>Search Results</span><h2><%= currentCat !== 'Zote' ? currentCat : 'All Software' %></h2></div><span><%= total %> results</span></div><form class="filter-panel" action="/" method="GET"><input type="hidden" name="q" value="<%= query || '' %>"><select name="cat"><option value="Zote">All Categories</option><% categories.forEach(c => { %><option value="<%= c.category %>" <%= currentCat === c.category ? 'selected' : '' %>><%= c.category %></option><% }) %></select><select name="platform"><% ['All','Windows','Android','macOS','iOS','Linux','Multi'].forEach(p => { %><option value="<%= p %>" <%= platform === p ? 'selected' : '' %>><%= p === 'All' ? 'All platforms' : p %></option><% }) %></select><select name="sort"><% [['trending','Trending'],['popular','Popular'],['newest','Newest'],['oldest','Oldest'],['downloads','Downloads']].forEach(item => { %><option value="<%= item[0] %>" <%= sort === item[0] ? 'selected' : '' %>><%= item[1] %></option><% }) %></select><button class="btn btn-secondary" type="submit">Apply</button></form><div class="software-grid"><% apps.forEach(app => { %><a class="software-card" href="/app/<%= app.slug %>"><div class="card-top"><div class="app-icon"><% if (app.icon_file_id) { %><img src="/icon/<%= app.icon_file_id %>" alt=""><% } else { %><%- include('partials/app-icon', { category: app.category }) %><% } %></div><span><%= app.version || 'v1.0' %></span></div><h3><%= app.name %></h3><p><%= app.category %> - <%= app.os || 'Multi' %></p><div class="metric-row"><span><%= fmt(app.downloads) %> downloads</span><span><%= app.file_size || 'N/A' %></span></div></a><% }) %></div><% if (apps.length === 0) { %><div class="empty-state">No software matched your filters.</div><% } %></section>
  <section class="newsletter"><h2>Stay updated with latest software.</h2><form><input type="email" placeholder="you@example.com"><button class="btn btn-primary" type="button">Notify me</button></form></section>
</main>
<%- include('partials/footer') %>
<%- include('partials/foot') %>