<%- include('partials/head', { title: 'Preparing Download - ' + app.name }) %>
<%- include('partials/nav') %>
<%
  const osExtMap = { Android: 'apk', Windows: 'exe', Mac: 'dmg', iOS: 'ipa', Linux: 'AppImage' };
  const fileExt = osExtMap[app.os] || 'apk';
  const cleanVersion = (app.version || 'v1.0').replace(/^v/i, '');
  const fileName = `${app.slug}-v${cleanVersion}-full.${fileExt}`;
%>
<main class="download-page">
  <section class="download-standalone" id="dlPanel" data-slug="<%= app.slug %>">

    <div class="dl-icon"><% if (app.icon_file_id) { %><img src="/icon/<%= app.icon_file_id %>" alt="<%= app.name %>"><% } else { %><%- include('partials/app-icon', { category: app.category }) %><% } %></div>

    <h1><%= app.name %> - <%= app.version || 'v1.0' %> - Mod</h1>

    <div id="dlStart">
      <p class="dl-filename">Ready to download <%= fileName %></p>
      <button type="button" class="btn-download" id="dlStartBtn">Download</button>
    </div>

    <div id="dlGenerating" hidden>
      <p class="dl-filename">You are downloading <%= fileName %></p>
      <p class="dl-status-sub">Your link is almost ready, please wait a few seconds...</p>
      <div class="progress-track"><div class="progress-fill" id="dlProgressFill"></div></div>
    </div>

    <div id="dlReady" hidden>
      <p class="dl-filename">You are downloading <%= fileName %></p>
      <a class="btn-download" id="dlFinalBtn" href="#">Download (<%= app.file_size || 'N/A' %>)</a>

      <div class="dl-note">Some download links are giving 404 errors, we are aware of this and working on a fix, thank you for your patience.</div>
      <div class="dl-note dl-note-ad">An ad will pop up before the download. Close it, click download again — ads keep us going, thanks!</div>
    </div>

    <div id="dlError" hidden>
      <p class="dl-status-text dl-error-text">Hitilafu imetokea, link haikupatikana.</p>
      <button type="button" class="btn-download" id="dlRetryBtn">Jaribu Tena</button>
    </div>

    <% if (process.env.TELEGRAM_CHANNEL_LINK) { %>
      <a class="telegram-btn" href="<%= process.env.TELEGRAM_CHANNEL_LINK %>" target="_blank" rel="noopener">Join @<%= siteName %> on Telegram channel</a>
    <% } %>

  </section>
</main>
<script src="/js/timer.js" defer></script>
<%- include('partials/foot') %>