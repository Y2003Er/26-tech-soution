<%- include('partials/head', { title: 'Preparing Download - ' + app.name }) %>
<%- include('partials/nav') %>
<main class="download-page">
  <section class="modal-panel download-standalone">
    <div class="modal-kicker">Secure Download</div>
    <h1>Preparing Download...</h1>
    <p class="download-name"><%= app.name %> - <%= app.version || 'v1.0' %> - <%= app.file_size || 'N/A' %></p>
    <div class="modal-checks"><span>Secure Server Connected</span><span>Virus Scan Passed</span><span>Fast Download Ready</span></div>
    <div class="countdown" id="standaloneCountdown">3</div>
    <a class="btn btn-primary manual-link" href="/go/<%= app.slug %>" id="manualDownload">Download Manually</a>
    <div class="download-related"><h2>Recommended after download</h2><p>Explore related apps from the marketplace once your file starts.</p><a href="/">Browse software</a></div>
  </section>
</main>
<script>(function(){var count=3;var el=document.getElementById('standaloneCountdown');var target='/go/<%= app.slug %>';var timer=setInterval(function(){count-=1;el.textContent=count>0?count:'Ready';if(count<=0){clearInterval(timer);window.location.href=target;}},1000);})();</script>
<%- include('partials/foot') %>