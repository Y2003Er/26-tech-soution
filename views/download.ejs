<%- include('partials/head', { title: 'Pakua — ' + app.name }) %>
<%- include('partials/nav') %>

<style>
  .dl-wrapper {
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5.5rem 1rem 2rem;
    box-sizing: border-box;
  }

  .dl-card {
    width: 100%;
    max-width: 480px;
    background: linear-gradient(145deg, #1a1a2e, #16213e);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 24px;
    padding: 2.5rem 2rem;
    box-sizing: border-box;
    text-align: center;
    box-shadow: 0 25px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.04);
    position: relative;
    overflow: hidden;
  }

  .dl-card::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(99,102,241,0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .dl-card::after {
    content: '';
    position: absolute;
    bottom: -60px; left: -60px;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(139,92,246,0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .dl-app-icon {
    width: 80px; height: 80px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    border-radius: 20px;
    margin: 0 auto 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 25px rgba(99,102,241,0.4);
  }

  .dl-app-icon svg { width: 36px; height: 36px; color: #fff; }

  .dl-badge {
    display: inline-block;
    background: rgba(99,102,241,0.15);
    border: 1px solid rgba(99,102,241,0.3);
    color: #a5b4fc;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
    border-radius: 100px;
    margin-bottom: 0.8rem;
  }

  .dl-app-name {
    font-size: 1.6rem;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 0.4rem;
    letter-spacing: -0.02em;
  }

  .dl-app-meta {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .dl-app-meta strong { color: rgba(255,255,255,0.65); }

  /* Loading State (Rotation animation badala ya countdown) */
  .timer-wrapper {
    position: relative;
    width: 110px; height: 110px;
    margin: 0 auto 2rem;
  }

  .timer-wrapper svg { animation: rotateLoading 2s linear infinite; }

  @keyframes rotateLoading {
    100% { transform: rotate(270deg); }
  }

  .timer-label {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    width: 100%;
  }

  .timer-label small {
    display: block;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.6);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: bold;
  }

  /* Info strip */
  .dl-info-strip {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 1.8rem;
  }

  .dl-info-item { text-align: center; }
  .dl-info-item .val { font-size: 0.85rem; font-weight: 700; color: #fff; }
  .dl-info-item .lbl { font-size: 0.65rem; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.08em; }
  .dl-divider { width: 1px; background: rgba(255,255,255,0.08); align-self: stretch; }

  /* Download link box */
  .dl-link-box {
    background: rgba(99,102,241,0.08);
    border: 1px solid rgba(99,102,241,0.25);
    border-radius: 12px;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .dl-link-label {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .dl-link-url {
    font-size: 0.78rem;
    color: #a5b4fc;
    word-break: break-all;
    font-family: monospace;
    margin-bottom: 0.8rem;
  }

  /* Button */
  .dl-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    padding: 1rem;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 14px;
    text-decoration: none;
    box-shadow: 0 8px 25px rgba(99,102,241,0.45);
    transition: transform 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
    cursor: pointer;
    border: none;
  }

  .dl-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 35px rgba(99,102,241,0.55);
  }

  .dl-btn:active { transform: translateY(0); }

  .dl-secure {
    margin-top: 1.2rem;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
  }
</style>

<div class="dl-wrapper">
  <div class="dl-card">

    <div class="dl-app-icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
        <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
      </svg>
    </div>

    <div class="dl-badge" id="statusBadge">Maandalizi</div>
    <div class="dl-app-name"><%= app.name %></div>
    
    <div class="dl-app-meta" id="dlMetaText">
      Bofya kitufe hapo chini ili kuanza kutengeneza kiungo cha kupakua.
    </div>

    <div id="actionStep1">
      <button onclick="triggerSilentDownload()" class="dl-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
        </svg>
        Anza Maandalizi ya APK
      </button>
    </div>

    <div class="timer-wrapper" id="timerSection" style="display: none;">
      <svg viewBox="0 0 100 100" width="110" height="110">
        <circle cx="50" cy="50" r="45" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="6"/>
        <circle id="timerCircle" cx="50" cy="50" r="45" fill="none"
          stroke="url(#grad)" stroke-width="6" stroke-linecap="round" stroke-dasharray="283" stroke-dashoffset="70"/>
        <defs>
          <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" style="stop-color:#6366f1"/>
            <stop offset="100%" style="stop-color:#8b5cf6"/>
          </linearGradient>
        </defs>
      </svg>
      <div class="timer-label">
        <small>Inaprosesi...</small>
      </div>
    </div>

    <div class="dl-info-strip">
      <div class="dl-info-item">
        <div class="val" id="infoSize"><%= app.file_size || 'Kutafuta...' %></div>
        <div class="lbl">Ukubwa</div>
      </div>
      <div class="dl-divider"></div>
      <div class="dl-info-item">
        <div class="val"><%= app.version %></div>
        <div class="lbl">Toleo</div>
      </div>
      <div class="dl-divider"></div>
      <div class="dl-info-item">
        <div class="val">APK</div>
        <div class="lbl">Aina</div>
      </div>
    </div>

    <div id="downloadAction" style="display:none;">
      <div class="dl-link-box">
        <div class="dl-link-label">🔗 Link yako iko tayari</div>
        <div class="dl-link-url" id="dlLinkUrl"></div>
        <a id="dlLinkBtn" href="#" class="dl-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
          </svg>
          Download APK Sasa
        </a>
      </div>
      <div class="dl-secure">
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
        </svg>
        Faili hili limethibitishwa na 26-Tech · Salama kupakua
      </div>
    </div>

  </div>
</div>

<script>
function triggerSilentDownload() {
  const actionStep1 = document.getElementById("actionStep1");
  const timerSection = document.getElementById("timerSection");
  const downloadAction = document.getElementById("downloadAction");
  const dlLinkUrl = document.getElementById("dlLinkUrl");
  const dlLinkBtn = document.getElementById("dlLinkBtn");
  const statusBadge = document.getElementById("statusBadge");
  const dlMetaText = document.getElementById("dlMetaText");
  const infoSize = document.getElementById("infoSize");

  // 1. Ficha kitufe cha kwanza, weka loading spinner ya kimya kimya
  actionStep1.style.display = "none";
  timerSection.style.display = "block";
  statusBadge.textContent = "Inatengeneza...";
  dlMetaText.innerHTML = "Tafadhali subiri kidogo, mfumo unatengeneza kiungo salama cha kupakua...";

  const slug = "<%= app.slug %>";

  // 2. Tuma ombi la chini kwa chini (Fetch) kwenda kutafuta link na size ya faili
  fetch(`/download/${slug}/generate`)
    .then(response => {
      if (!response.ok) throw new Error('Hitilafu ya mtandao');
      return response.json();
    })
    .then(data => {
      if (data.success) {
        // Nenda kwenye hatua ya 3: Ficha spinner, onyesha kitufe cha mwisho
        timerSection.style.display = "none";
        statusBadge.textContent = "Tayari";
        statusBadge.style.background = "rgba(16, 185, 129, 0.15)";
        statusBadge.style.color = "#10b981";
        statusBadge.style.borderColor = "rgba(16, 185, 129, 0.3)";
        dlMetaText.innerHTML = "Kiungo kimetengenezwa kwa ufanisi! Unaweza kupakua faili lako sasa.";

        // Weka taarifa sahihi zilizotoka kwenye seva
        infoSize.textContent = data.size;
        dlLinkUrl.textContent = window.location.origin + data.downloadUrl;
        dlLinkBtn.href = data.downloadUrl;

        // Fungua kibox cha mwisho cha download
        downloadAction.style.display = "block";
      } else {
        alert("Hitilafu: " + (data.message || "Imeshindwa kupata faili."));
        window.location.reload();
      }
    })
    .catch(err => {
      console.error("Error fetching download link:", err);
      alert("Mchakato umeshindwa. Tafadhali jaribu tena.");
      window.location.reload();
    });
}
</script>

<%- include('partials/foot') %>
