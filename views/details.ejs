<%- include('partials/head', { title: app ? app.name + ' - 26 Tech' : 'Software Details' }) %>
<%- include('partials/nav') %>
<% const fmt = n => Number(n || 0).toLocaleString(); const dateFmt = d => d ? new Date(d).toLocaleDateString('en', { month: 'long', day: 'numeric', year: 'numeric' }) : 'Recently'; %>
<main class="details-page">
  <% if (app) { %>
  <section class="details-hero">
    <div class="details-icon"><% if (app.icon_file_id) { %><img src="/icon/<%= app.icon_file_id %>" alt="<%= app.name %>"><% } else { %><%- include('partials/app-icon', { category: app.category }) %><% } %></div>
    <div class="details-title-block"><div class="eyebrow"><%= app.category || 'Software' %> by verified developer</div><h1><%= app.name %></h1><p><%= app.description || 'Verified software available from 26 Tech Solution.' %></p><div class="detail-tags"><span>Rating 4.<%= (app.id || 8) % 9 %></span><span><%= fmt(app.downloads) %> downloads</span><span><%= app.version || 'v1.0' %></span><span>Virus scan passed</span></div></div>
    <aside class="download-panel"><div class="price-pill"><%= app.is_free ? 'Free download' : 'Premium listing' %></div><a class="btn btn-primary big" href="/download/<%= app.slug %>" data-download-url="/go/<%= app.slug %>" data-download-name="<%= app.name %>">Download Now</a><button class="btn btn-secondary" type="button" data-copy-link>Copy Link</button></aside>
  </section>
  <section class="details-grid">
    <div class="details-main">
      <div class="screenshot-gallery"><div>Screenshot Gallery</div><div>Preview</div><div>Interface</div></div>
      <article class="glass-panel"><h2>Description</h2><p><%= app.description || 'No additional description has been added yet.' %></p></article>
      <article class="glass-panel"><h2>Features</h2><ul class="feature-list"><li>Verified download source</li><li>Fast secure server handoff</li><li>Clean version and file metadata</li><li>Compatible with <%= app.os || 'modern platforms' %></li></ul></article>
      <article class="glass-panel"><h2>Changelog</h2><p>Latest version <strong><%= app.version || 'v1.0' %></strong> was updated <%= dateFmt(app.updated_at || app.created_at) %>.</p></article>
      <article class="glass-panel comments"><h2>Comments</h2><p>Community comments can connect here when moderation is added. The layout is ready without changing the current backend.</p></article>
    </div>
    <aside class="spec-panel glass-panel"><h2>File Information</h2><dl><div><dt>Developer</dt><dd>Verified Publisher</dd></div><div><dt>Version</dt><dd><%= app.version || 'v1.0' %></dd></div><div><dt>File Size</dt><dd><%= app.file_size || 'N/A' %></dd></div><div><dt>Compatibility</dt><dd><%= app.os || 'Multi-platform' %></dd></div><div><dt>Last Update</dt><dd><%= dateFmt(app.updated_at || app.created_at) %></dd></div><div><dt>Virus Scan</dt><dd class="safe">Passed</dd></div><div><dt>Views</dt><dd><%= fmt(app.views) %></dd></div></dl><div class="share-row"><button type="button" data-copy-link>Share</button><button type="button" data-copy-link>Copy Link</button></div></aside>
  </section>
  <section class="section"><div class="section-head"><div><span>Related Software</span><h2>You may also like</h2></div></div><div class="software-grid"><% related.forEach(item => { %><a class="software-card" href="/app/<%= item.slug %>"><div class="card-top"><div class="app-icon"><% if (item.icon_file_id) { %><img src="/icon/<%= item.icon_file_id %>" alt=""><% } else { %><%- include('partials/app-icon', { category: item.category }) %><% } %></div><span><%= item.version || 'v1.0' %></span></div><h3><%= item.name %></h3><p><%= item.category %></p><div class="metric-row"><span><%= fmt(item.downloads) %> downloads</span><span><%= item.file_size || 'N/A' %></span></div></a><% }) %></div></section>
  <% } else { %><div class="empty-state">Software not found.</div><% } %>
</main>
<%- include('partials/footer') %>
<%- include('partials/foot') %>