<%- include('partials/head', { title: title }) %>
<%- include('partials/nav') %>
<%
const dateFmt = d => d ? new Date(d).toLocaleDateString('en', { month: 'short', day: 'numeric', year: 'numeric' }) : 'Recently';

const buildBadges = (a) => {
  const list = [];
  if (a.is_editors_choice) list.push({ text: "Editor's Choice", cls: 'badge-choice' });
  if (a.badges && a.badges.length) {
    a.badges.forEach(b => {
      const lower = b.toLowerCase();
      let cls = 'badge-mod';
      if (lower === 'online') cls = 'badge-online';
      else if (lower === 'offline') cls = 'badge-offline';
      else if (lower === 'premium') cls = 'badge-premium';
      list.push({ text: b, cls });
    });
  }
  return list;
};

const badges = buildBadges(app);
const ratingText = (app.rating && app.rating > 0) ? Number(app.rating).toFixed(1) : null;
const heroStyle = app.banner_file_id ? `background-image:url('/icon/${app.banner_file_id}')` : '';
%>
<main class="details-page">

  <section class="details-hero">
    <div class="details-hero-banner" style="<%= heroStyle %>">
      <% if (badges.length) { %>
        <div class="details-hero-badges"><% badges.forEach(b => { %><span class="badge <%= b.cls %>"><%= b.text %></span><% }) %></div>
      <% } %>
      <div class="details-hero-overlay">
        <div class="details-icon">
          <% if (app.icon_file_id) { %>
            <img src="/icon/<%= app.icon_file_id %>" alt="<%= app.name %>" style="width:100%;height:100%;object-fit:cover;border-radius:22px">
          <% } else { %>
            <%- include('partials/app-icon', { category: app.category }) %>
          <% } %>
        </div>
        <div class="details-title-block">
          <h1><%= app.name %></h1>
          <p><%= app.developer || 'Verified Publisher' %></p>
          <div class="detail-tags">
            <span><%= app.category %></span>
            <span><%= app.os || 'Multi' %></span>
            <span><%= app.version || 'v1.0' %></span>
            <% if (ratingText) { %><span>★ <%= ratingText %></span><% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="details-hero-panel">
      <span class="price-pill <%= app.is_free ? 'free' : 'paid' %>"><%= app.is_free ? 'Free' : 'Premium' %></span>
      <div class="download-panel">
        <a class="btn btn-primary big" href="/download/<%= app.slug %>">Download Now</a>
        <span class="safe">✓ Verified safe file</span>
      </div>
    </div>
  </section>

  <div class="details-grid">
    <div class="details-main">

      <% if (app.screenshots && app.screenshots.length) { %>
        <div class="screenshot-gallery">
          <% app.screenshots.slice(0,3).forEach(shot => { %>
            <div style="background-image:url('<%= shot %>');background-size:cover;background-position:center"></div>
          <% }) %>
        </div>
      <% } %>

      <div class="glass-panel">
        <h2>About this <%= app.category === 'Games' ? 'game' : 'app' %></h2>
        <p><%= app.description %></p>
      </div>

      <% if (app.mod_info || badges.length) { %>
        <div class="glass-panel">
          <h2>What's included</h2>
          <ul class="feature-list">
            <% if (app.mod_info) { %><li><%= app.mod_info %></li><% } %>
            <% badges.forEach(b => { %><li><%= b.text %></li><% }) %>
          </ul>
        </div>
      <% } %>
    </div>

    <aside class="spec-panel glass-panel">
      <dl>
        <div><dt>Developer</dt><dd><%= app.developer || 'Verified Publisher' %></dd></div>
        <% if (app.package_name) { %><div><dt>Package</dt><dd><%= app.package_name %></dd></div><% } %>
        <div><dt>Version</dt><dd><%= app.version || 'v1.0' %></dd></div>
        <div><dt>Size</dt><dd><%= app.file_size || 'N/A' %></dd></div>
        <div><dt>Platform</dt><dd><%= app.os || 'Multi' %></dd></div>
        <div><dt>Category</dt><dd><%= app.category %></dd></div>
        <div><dt>Downloads</dt><dd><%= Number(app.downloads || 0).toLocaleString() %></dd></div>
        <div><dt>Updated</dt><dd><%= dateFmt(app.updated_at || app.created_at) %></dd></div>
      </dl>
      <div class="share-row">
        <button type="button" data-copy-link>Copy Link</button>
        <button type="button" data-share-app data-share-title="<%= app.name %>" data-share-text="Check out <%= app.name %> on 26 Tech">Share</button>
      </div>
    </aside>
  </div>

  <% if (related && related.length) { %>
    <section class="section">
      <div class="section-head"><div><span>You may also like</span><h2>More in <%= app.category %></h2></div></div>
      <div class="software-grid">
        <% related.forEach(r => { %>
          <a class="software-card" href="/app/<%= r.slug %>">
            <div class="card-top">
              <div class="app-icon"><% if (r.icon_file_id) { %><img src="/icon/<%= r.icon_file_id %>" alt=""><% } else { %><%- include('partials/app-icon', { category: r.category }) %><% } %></div>
              <span><%= r.version || 'v1.0' %></span>
            </div>
            <h3><%= r.name %></h3>
            <p><%= r.category %></p>
            <% if (r.rating && r.rating > 0) { %><span class="rating-row">★ <%= Number(r.rating).toFixed(1) %></span><% } %>
            <div class="metric-row"><span><%= Number(r.downloads || 0).toLocaleString() %> downloads</span><span><%= r.file_size || 'N/A' %></span></div>
          </a>
        <% }) %>
      </div>
    </section>
  <% } %>

</main>
<%- include('partials/footer') %>
<%- include('partials/foot') %>