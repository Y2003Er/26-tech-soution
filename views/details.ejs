<%- include('partials/head', { title: app ? app.name : 'Maelezo ya Programu' }) %>
<%- include('partials/nav') %>

<main class="container" style="padding-top: 5.5rem; max-width: 1100px; margin: 0 auto; padding-left: 1rem; padding-right: 1rem;">
  <% if (app) { %>
    
    <div style="display: flex; flex-wrap: wrap; gap: 2rem; margin-top: 1.5rem; align-items: flex-start;">
      
      <div style="flex: 1; min-width: 300px;">
        <div style="display: flex; gap: 1.5rem; align-items: center; background: var(--card); border: 1px solid var(--border); padding: 1.5rem; border-radius: var(--r);">
          <div style="width: 100px; height: 100px; background: var(--surface); border-radius: 16px; overflow: hidden; flex-shrink: 0; border: 1px solid var(--border-lit);">
            <% if (app.icon_file_id) { %>
              <img src="/icon/<%= app.icon_file_id %>" alt="<%= app.name %>" style="width: 100%; height: 100%; object-fit: cover;">
            <% } else { %>
              <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-family: var(--f-mono); font-size: 0.8rem; color: var(--dim);">APP</div>
            <% } %>
          </div>
          <div style="min-width: 0;">
            <h1 style="font-family: var(--f-display); font-size: 1.5rem; font-weight: 800; color: var(--white); margin: 0 0 0.4rem 0; line-height: 1.2;"><%= app.name %></h1>
            <div style="display: flex; flex-wrap: wrap; gap: 8px; font-family: var(--f-mono); font-size: 0.7rem;">
              <span style="background: var(--surface); padding: 0.2rem 0.6rem; border-radius: 4px; color: var(--dim);">Kundi: <%= app.category || 'App' %></span>
              <span style="background: rgba(200, 255, 0, 0.08); border: 1px solid rgba(200, 255, 0, 0.25); padding: 0.2rem 0.6rem; border-radius: 4px; color: var(--accent); font-weight: 700;">Toleo: <%= app.version || 'v1.0' %></span>
            </div>
          </div>
        </div>

        <div style="margin-top: 2rem;">
          <h3 style="font-family: var(--f-display); font-size: 1.1rem; font-weight: 800; text-transform: uppercase; color: var(--white); margin-bottom: 0.8rem;">Kuhusu Programu Hii</h3>
          <div style="font-family: var(--f-body); font-size: 0.88rem; color: var(--dim); line-height: 1.6; background: var(--card); border: 1px solid var(--border); padding: 1.5rem; border-radius: var(--r);">
            <%= app.description || 'Hakuna maelezo ya ziada yaliyowekwa.' %>
          </div>
        </div>
      </div>

      <div style="width: 320px; flex-shrink: 0; background: var(--card); border: 1px solid var(--border); padding: 1.5rem; border-radius: var(--r); box-sizing: border-box;">
        <h3 style="font-family: var(--f-display); font-size: 0.95rem; font-weight: 800; text-transform: uppercase; color: var(--white); margin: 0 0 1.2rem 0; letter-spacing: 0.05em;">Vigezo vya Faili</h3>
        
        <div style="display: grid; grid-template-columns: 1fr; gap: 0.75rem; margin-bottom: 1.5rem; font-family: var(--f-body); font-size: 0.82rem;">
          <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">
            <span style="color: var(--dim);">Ukubwa:</span>
            <span style="color: var(--white); font-weight: 700; font-family: var(--f-mono);"><%= app.file_size || 'N/A' %></span>
          </div>
          <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;">
            <span style="color: var(--dim);">Mfumo:</span>
            <span style="color: var(--white); font-weight: 700;"><%= app.os || 'N/A' %></span>
          </div>
        </div>

        <a href="/download/<%= app.slug %>" class="dl-btn" style="text-decoration: none; display: flex; align-items: center; justify-content: center; background: var(--accent); color: #000; font-family: var(--f-mono); font-size: 0.85rem; font-weight: 800; padding: 0.9rem; border-radius: var(--r-sm); transition: opacity 0.2s; width: 100%; text-align: center; box-sizing: border-box;" onmouseover="this.style.opacity='0.9';" onmouseout="this.style.opacity='1';">
          PAKUA SASA
        </a>
      </div>

    </div>

  <% } else { %>
    <div style="padding: 4rem 1rem; text-align: center;">
      <p style="font-family: var(--f-body); color: var(--dim); font-size: 0.9rem;">Programu haikupatikana.</p>
    </div>
  <% } %>
</main>

<%- include('partials/foot') %>