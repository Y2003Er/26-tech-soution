<%- include('partials/head', { title: app ? app.name + ' - 26 Tech' : 'Software Details' }) %>
<%- include('partials/nav') %>
<%
const fmt = n => Number(n || 0).toLocaleString();
const dateFmt = d => d ? new Date(d).toLocaleDateString('en', { month: 'long', day: 'numeric', year: 'numeric' }) : 'Recently';

// Helper: badges za app (Editor's Choice, MOD/PREMIUM, ONLINE/OFFLINE)
const buildBadges = (a) => {
  const list = [];
  if (a.is_editors_choice) list.push({ text: "Editor's Choice", cls: 'badge-choice' });
  if (a.badges && a.badges.length) {
    a.badges.forEach(b => {
      const lower = b.toLowerCase();
      let cls = 'badge-mod';
      if (lower === 'online') cls = 'badge-online';
      else if (lower === 'offline') cls = 'badge-offline';
      else if (lower === 'premium') cls = 'badge-premium';
      list.push({ text: b, cls });
    });
  }
  return list;
};
const ratingText = (a) => (a && a.rating && a.rating > 0) ? Number(a.rating).toFixed(1) : null;
const badges = app ? buildBadges(app) : [];
%>
<main class="details-page">
  <% if (app) { %>

  <!-- ════════ DETAILS HERO - banner + overlay kama LiteAPKs ════════ -->
  <section class="details-hero">
    <div class="details-hero-banner" <% if (app.banner_file_id) { %>style="background-image: url('/icon/<%= app.banner_file_id %>')"<% } else if (app.screenshots && app.screenshots.length) { %>style="background-image: url('<%= app.screenshots[0] %>')"<% } %>>
      <% if (badges.length) { %>
        <div class="details-hero-badges">
          <% badges.forEach(b => { %><span class="badge <%= b.cls %>"><%= b.text %></span><% }) %>
        </div>
      <% } %>

      <div class="details-hero-overlay">
        <div class="details-icon">
          <% if (app.icon_file_id) { %><img src="/icon/<%= app.icon_file_id %>" alt="<%= app.name %>"><% } else { %><%- include('partials/app-icon', { category: app.category }) %><% } %>
        </div>
        <div class="details-title-block">
          <h1><%= app.name %></h1>
          <p><%= app.category || 'Software' %> by <%= app.developer || 'Verified Publisher' %></p>
          <div class="detail-tags">
            <% if (ratingText(app)) { %><span class="rating-row">★ <%= ratingText(app) %></span><% } else { %><span>No ratings yet</span><% } %>
            <span><%= fmt(app.downloads) %> downloads</span>
            <span><%= app.version || 'v1.0' %></span>
            <% if (app.mod_info) { %><span class="mod-line"><%= app.mod_info %></span><% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="details-hero-panel">
      <div class="price-pill <%= app.is_free ? 'free' : 'paid' %>"><%= app.is_free ? 'Free Download' : 'Premium Listing' %></div>
      <div class="download-panel">
        <a class="btn btn-primary big" href="/download/<%= app.slug %>">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
          <span>Download Now</span>
        </a>
        <button class="btn btn-secondary" type="button" data-share-app data-share-title="<%= app.name %>" data-share-text="<%= app.name %> - <%= app.category %> kutoka 26 Tech Solution">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
          <span>Share</span>
        </button>
      </div>
    </div>
  </section>

  <section class="details-grid">
    <div class="details-main">
      <% if (app.screenshots && app.screenshots.length) { %>
        <div class="screenshot-gallery has-images">
          <% app.screenshots.forEach(shot => { %>
            <a href="<%= shot %>" target="_blank" rel="noopener" class="screenshot-thumb">
              <img src="<%= shot %>" alt="<%= app.name %> screenshot" loading="lazy" style="width:100%;height:100%;object-fit:cover;border-radius:22px">
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <div class="screenshot-gallery">
          <div style="display:grid;place-items:center;background:linear-gradient(135deg,rgba(255,255,255,.08),rgba(124,58,237,.1));color:#dbeafe;font-weight:900">Screenshot Gallery</div>
          <div style="display:grid;place-items:center;background:linear-gradient(135deg,rgba(255,255,255,.08),rgba(124,58,237,.1));color:#dbeafe;font-weight:900">Preview</div>
          <div style="display:grid;place-items:center;background:linear-gradient(135deg,rgba(255,255,255,.08),rgba(124,58,237,.1));color:#dbeafe;font-weight:900">Interface</div>
        </div>
      <% } %>

      <article class="glass-panel"><h2>Description</h2><p><%= app.description || 'No additional description has been added yet.' %></p></article>
      <article class="glass-panel"><h2>Features</h2><ul class="feature-list"><li>Verified download source</li><li>Fast secure server handoff</li><li>Clean version and file metadata</li><li>Compatible with <%= app.os || 'modern platforms' %></li></ul></article>
      <article class="glass-panel"><h2>Changelog</h2><p>Latest version <strong><%= app.version || 'v1.0' %></strong> was updated <%= dateFmt(app.updated_at || app.created_at) %>.</p></article>
      <article class="glass-panel comments"><h2>Comments</h2><p>Community comments can connect here when moderation is added. The layout is ready without changing the current backend.</p></article>
    </div>

    <aside class="spec-panel glass-panel">
      <h2>File Information</h2>
      <dl>
        <div><dt>Developer</dt><dd><%= app.developer || 'Verified Publisher' %></dd></div>
        <% if (app.package_name) { %><div><dt>Package Name</dt><dd><%= app.package_name %></dd></div><% } %>
        <div><dt>Version</dt><dd><%= app.version || 'v1.0' %></dd></div>
        <div><dt>File Size</dt><dd><%= app.file_size || 'N/A' %></dd></div>
        <div><dt>Compatibility</dt><dd><%= app.os || 'Multi-platform' %></dd></div>
        <div><dt>Last Update</dt><dd><%= dateFmt(app.updated_at || app.created_at) %></dd></div>
        <% if (ratingText(app)) { %><div><dt>Rating</dt><dd class="rating-row">★ <%= ratingText(app) %> / 5.0</dd></div><% } %>
        <div><dt>Views</dt><dd><%= fmt(app.views) %></dd></div>
      </dl>
      <div class="share-row">
        <button type="button" data-share-app data-share-title="<%= app.name %>" data-share-text="<%= app.name %> - <%= app.category %> kutoka 26 Tech Solution">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
          <span>Share</span>
        </button>
        <button type="button" data-copy-link>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          <span>Copy Link</span>
        </button>
      </div>
    </aside>
  </section>

  <section class="section">
    <div class="section-head"><div><span>Related Software</span><h2>You may also like</h2></div></div>
    <div class="software-grid">
      <% related.forEach(item => { %>
        <a class="software-card" href="/app/<%= item.slug %>">
          <% const itemBadges = buildBadges(item); %>
          <div class="card-banner" <% if (item.banner_file_id) { %>style="background-image:url('/icon/<%= item.banner_file_id %>')"<% } else if (item.screenshots && item.screenshots.length) { %>style="background-image:url('<%= item.screenshots[0] %>')"<% } %>>
            <% if (itemBadges.length) { %>
              <div class="badge-wrap"><% itemBadges.forEach(b => { %><span class="badge <%= b.cls %>"><%= b.text %></span><% }) %></div>
            <% } %>
            <div class="card-banner-overlay">
              <div class="app-icon"><% if (item.icon_file_id) { %><img src="/icon/<%= item.icon_file_id %>" alt=""><% } else { %><%- include('partials/app-icon', { category: item.category }) %><% } %></div>
              <div>
                <strong><%= item.name %></strong>
                <span><%= item.category %></span>
              </div>
            </div>
          </div>
          <div class="card-body">
            <span class="metric-row"><span><%= item.version || 'v1.0' %></span></span>
            <% if (ratingText(item)) { %><span class="rating-row">★ <%= ratingText(item) %></span><% } %>
            <% if (item.mod_info) { %><div class="mod-line"><%= item.mod_info %></div><% } %>
            <div class="metric-row"><span><%= fmt(item.downloads) %> downloads</span><span><%= item.file_size || 'N/A' %></span></div>
          </div>
        </a>
      <% }) %>
    </div>
  </section>

  <% } else { %><div class="empty-state">Software not found.</div><% } %>
</main>
<%- include('partials/footer') %>
<%- include('partials/foot') %>