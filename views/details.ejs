/* ════════ DETAILS HERO - yenye background image kama LiteAPKs ════════ */
.details-hero {
  position: relative;
  display: grid;
  grid-template-columns: auto minmax(0,1fr) 280px;
  gap: 24px;
  align-items: center;
  padding: 28px;
  border: 1px solid rgba(255,255,255,.11);
  border-radius: 30px;
  background: linear-gradient(135deg,rgba(124,58,237,.20),rgba(14,165,233,.08));
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  box-shadow: 0 30px 90px rgba(0,0,0,.3);
  overflow: hidden;
  isolation: isolate;
}

/* Overlay ya giza juu ya background image */
.details-hero::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(135deg, rgba(7,8,18,.88), rgba(12,15,30,.65));
}

/* Yaliyomo yote yawe juu ya overlay */
.details-hero > * {
  position: relative;
  z-index: 2;
}