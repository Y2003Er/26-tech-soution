<%- include('partials/head', { title }) %>
<%- include('partials/nav') %>
<div class="l1 light"></div>

<div class="section" style="padding-top:6rem">
  <div class="details-grid">

    <!-- LEFT: Main content -->
    <div class="details-main">
      <div class="details-thumb"><%= app.icon %></div>
      <div class="details-meta">
        <span class="meta-chip"><%= app.category %></span>
        <span class="meta-chip"><%= app.os %></span>
        <span class="meta-chip"><%= app.version %></span>
        <span class="meta-chip"><%= app.file_size %></span>
        <span class="badge <%= app.is_free ? 'badge-free' : 'badge-pro' %>">
          <%= app.is_free ? 'BURE' : 'PREMIUM' %>
        </span>
      </div>
      <h1 class="details-title"><%= app.name %></h1>
      <p class="details-desc"><%= app.description %></p>

      <!-- Stats strip -->
      <div style="display:flex;gap:1.5rem;margin-bottom:2rem;flex-wrap:wrap;">
        <div>
          <div style="font-family:var(--f-display);font-size:1.4rem;font-weight:800;letter-spacing:-.03em">
            <%= app.downloads.toLocaleString() %>
          </div>
          <div style="font-family:var(--f-mono);font-size:.58rem;letter-spacing:.14em;color:var(--dim);margin-top:.2rem">DOWNLOADS</div>
        </div>
        <div>
          <div style="font-family:var(--f-display);font-size:1.4rem;font-weight:800;letter-spacing:-.03em">
            <%= app.views.toLocaleString() %>
          </div>
          <div style="font-family:var(--f-mono);font-size:.58rem;letter-spacing:.14em;color:var(--dim);margin-top:.2rem">VIEWS</div>
        </div>
      </div>
    </div>

    <!-- RIGHT: Sidebar -->
    <div class="details-sidebar">
      <div class="sidebar-card">
        <span class="sidebar-icon"><%= app.icon %></span>
        <div class="sidebar-name"><%= app.name %></div>
        <div class="sidebar-ver">VERSION <%= app.version %> · <%= app.os.toUpperCase() %></div>

        <a href="/download/<%= app.slug %>" class="dl-btn">
          ⬇ Pakua Bure
        </a>

        <div class="sidebar-stats">
          <div class="stat-item">
            <div class="stat-val"><%= app.file_size %></div>
            <div class="stat-key">UKUBWA</div>
          </div>
          <div class="stat-item">
            <div class="stat-val"><%= app.os %></div>
            <div class="stat-key">MFUMO</div>
          </div>
          <div class="stat-item">
            <div class="stat-val"><%= app.downloads.toLocaleString() %></div>
            <div class="stat-key">DOWNLOADS</div>
          </div>
          <div class="stat-item">
            <div class="stat-val"><%= app.is_free ? 'Bure' : 'Premium' %></div>
            <div class="stat-key">AINA</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Related apps -->
  <% if (related.length > 0) { %>
    <div style="margin-top:3rem;">
      <div class="sec-eyebrow">// RELATED</div>
      <div class="sec-title" style="margin-bottom:1.25rem">Software Zinazofanana</div>
      <div class="related-grid">
        <% related.forEach(r => { %>
          <a href="/app/<%= r.slug %>" class="rel-card">
            <span class="rel-icon"><%= r.icon %></span>
            <div>
              <div class="rel-name"><%= r.name %></div>
              <div class="rel-size"><%= r.file_size %> · <%= r.version %></div>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
<%- include('partials/foot') %>
