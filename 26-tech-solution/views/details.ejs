<%- include('partials/head', { title }) %>
<%- include('partials/nav') %>

<div class="details-wrap">
  <!-- LEFT: Main -->
  <div class="details-main">

    <!-- Header -->
    <div class="details-header">
      <div class="details-main-icon"><%= app.icon %></div>
      <div>
        <h1 class="details-title"><%= app.name %></h1>
        <div class="details-cats">
          <span class="mod-tag"><%= app.category %></span>
          <span class="mod-tag"><%= app.os %></span>
          <span class="mod-tag <%= app.is_free ? 'green' : 'orange' %>">
            <%= app.is_free ? 'BURE' : 'PREMIUM' %>
          </span>
        </div>
        <div class="details-rating">
          <span style="color:#f59e0b">★★★★</span>★
          <span>4.2 · <%= app.downloads.toLocaleString() %> downloads</span>
        </div>
      </div>
    </div>

    <!-- MOD Features box -->
    <div class="mod-features">
      <div class="mod-features-title">⚡ MOD FEATURES — <%= app.version %></div>
      <ul class="mod-features-list">
        <li>Premium Unlocked — Tumia vipengele vyote bila malipo</li>
        <li>Ads Removed — Hakuna matangazo yanayokusumbua</li>
        <li>Latest Version — Toleo jipya zaidi, lililosasishwa</li>
        <li>No Root Required — Hakuna haja ya Root kwenye simu</li>
      </ul>
    </div>

    <!-- Description -->
    <div style="font-size:.75rem;font-weight:700;letter-spacing:.1em;color:var(--dim);margin-bottom:.5rem;">MAELEZO</div>
    <p class="details-desc"><%= app.description %></p>

    <!-- Info table -->
    <div style="font-size:.75rem;font-weight:700;letter-spacing:.1em;color:var(--dim);margin-bottom:.5rem;">TAARIFA ZA APP</div>
    <table class="info-table">
      <tr><td>Jina</td><td><%= app.name %></td></tr>
      <tr><td>Toleo</td><td><%= app.version %></td></tr>
      <tr><td>Mfumo</td><td><%= app.os %></td></tr>
      <tr><td>Ukubwa</td><td><%= app.file_size %></td></tr>
      <tr><td>Aina</td><td><%= app.is_free ? 'Bure' : 'Premium' %></td></tr>
      <tr><td>Downloads</td><td><%= app.downloads.toLocaleString() %></td></tr>
      <tr><td>Views</td><td><%= app.views.toLocaleString() %></td></tr>
    </table>

    <!-- Related apps -->
    <% if (related.length > 0) { %>
    <div style="font-size:.75rem;font-weight:700;letter-spacing:.1em;color:var(--dim);margin-bottom:.75rem;margin-top:1.5rem;">
      ZINAZOFANANA
    </div>
    <div class="app-list">
      <% related.forEach(r => { %>
      <a href="/app/<%= r.slug %>" class="app-row">
        <div class="app-row-icon"><%= r.icon %></div>
        <div class="app-row-info">
          <div class="app-row-name"><%= r.name %></div>
          <div class="app-row-meta">
            <span class="app-row-cat"><%= r.category %></span>
            <span class="mod-tag"><%= r.version %></span>
          </div>
        </div>
        <div class="app-row-right">
          <span class="app-row-size"><%= r.file_size %></span>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>

  </div>

  <!-- RIGHT: Sidebar -->
  <aside>
    <div class="dl-card">
      <span class="dl-card-icon"><%= app.icon %></span>
      <div class="dl-card-name"><%= app.name %></div>
      <div class="dl-card-ver">VERSION <%= app.version %> · <%= app.os.toUpperCase() %></div>

      <a href="/download/<%= app.slug %>" class="dl-btn-main">
        ⬇ Pakua Bure
      </a>

      <div style="font-size:.7rem;color:var(--dim);text-align:center;margin-bottom:.75rem;">
        Ukubwa: <strong style="color:var(--white)"><%= app.file_size %></strong>
      </div>

      <div class="dl-card-stats">
        <div class="dl-stat">
          <div class="dl-stat-val"><%= app.downloads.toLocaleString() %></div>
          <div class="dl-stat-key">DOWNLOADS</div>
        </div>
        <div class="dl-stat">
          <div class="dl-stat-val"><%= app.views.toLocaleString() %></div>
          <div class="dl-stat-key">VIEWS</div>
        </div>
        <div class="dl-stat">
          <div class="dl-stat-val"><%= app.version %></div>
          <div class="dl-stat-key">TOLEO</div>
        </div>
        <div class="dl-stat">
          <div class="dl-stat-val"><%= app.is_free ? 'Bure' : 'Pro' %></div>
          <div class="dl-stat-key">AINA</div>
        </div>
      </div>
    </div>
  </aside>

</div><!-- /details-wrap -->

<%- include('partials/footer') %>
<%- include('partials/foot') %>
