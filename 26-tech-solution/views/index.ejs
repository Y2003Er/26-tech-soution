<%- include('partials/head', { title: '26 TECH — Software Hub' }) %>
<%- include('partials/nav') %>

<div class="hero-banner">
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-tag"><span class="hero-tag-dot"></span> SOFTWARE HUB</div>
      <h1 class="hero-h1" style="text-transform: uppercase;">SOFTWARE HUB</h1>
      
      <div style="margin-top: 1.2rem; display: flex; flex-wrap: wrap; gap: 0.8rem; font-family: var(--f-mono); font-size: 0.85rem;">
        <a href="/?cat=Windows" style="color: var(--accent); text-decoration: none; font-weight: 700; border-bottom: 1px dashed var(--accent);">Windows</a>
        <span style="color: var(--dim);">·</span>
        <a href="/?cat=Android" style="color: var(--accent); text-decoration: none; font-weight: 700; border-bottom: 1px dashed var(--accent);">Android</a>
        <span style="color: var(--dim);">·</span>
        <a href="/?cat=macOS" style="color: var(--accent); text-decoration: none; font-weight: 700; border-bottom: 1px dashed var(--accent);">macOS</a>
        <span style="color: var(--dim);">·</span>
        <a href="/?cat=Games" style="color: var(--accent); text-decoration: none; font-weight: 700; border-bottom: 1px dashed var(--accent);">Games</a>
      </div>
    </div>
    
    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-num"><%= total %>+</div>
        <div class="hero-stat-label">SOFTWARE</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">50K+</div>
        <div class="hero-stat-label">WATUMIAJI</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">24/7</div>
        <div class="hero-stat-label">SUPPORT</div>
      </div>
    </div>
  </div>
</div>

<div class="page-wrap" style="flex: 1; display: flex; flex-direction: column;">

  <div class="filter-bar">
    <a href="/" class="filter-pill <%= currentCat === 'Zote' && !query ? 'active' : '' %>">Zote</a>
    <% categories.forEach(c => { %>
      <a href="/?cat=<%= encodeURIComponent(c.category) %>" class="filter-pill <%= currentCat === c.category ? 'active' : '' %>">
        <%= c.category %>
      </a>
    <% }) %>
    <% if (query) { %>
      <span class="filter-query">Matokeo ya "<strong><%= query %></strong>" — <%= total %></span>
    <% } %>
  </div>

  <div class="section-head">
    <div class="section-title"><%= currentCat !== 'Zote' ? currentCat : 'Software Zote' %></div>
  </div>

  <% if (apps.length === 0) { %>
    <div class="empty-state" style="margin-bottom: auto; padding: 6rem 1rem; text-align: center;">
      Hakuna software iliyopatikana.
    </div>
  <% } else { %>
    <div class="app-grid">
      <% apps.forEach(app => {
        const stars = (3 + Math.random() * 2).toFixed(1);
      %> 
      <a href="/details/<%= app.slug %>" class="app-card">
        <div class="app-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm7 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8zm0 2a2 2 0 1 1 0 4 2 2 0 0 1 0-4zm-7 9.5c0-1.5 3.13-2.5 7-2.5s7 1 7 2.5V19H5v-.5z"/></svg>
        </div>
        <div class="app-card-body">
          <div class="app-card-name"><%= app.name %></div>
          <div class="app-card-meta">
            <div class="app-card-rating">
              <span><%= stars %></span>
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            </div>
            <span class="dot">·</span>
            <span class="app-card-cat"><%= app.category %></span>
          </div>
          <div class="app-card-mod">
            <span class="mod-tag"><%= app.version %></span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  <% } %>

</div>

<%- include('partials/footer') %>
<%- include('partials/foot') %>