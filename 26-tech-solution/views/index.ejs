<%- include('partials/head', { title }) %>
<%- include('partials/nav') %>

<!-- HERO BANNER -->
<div class="hero-banner">
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-tag"><span class="hero-tag-dot"></span> #1 SOFTWARE HUB YA AFRICA</div>
      <h1 class="hero-h1">Pakua Software Yoyote<br/><em>Bure Kabisa</em></h1>
      <p class="hero-sub">Windows, Android, macOS, Games — toleo kamili, tayari kutumika.</p>
      <div class="hero-quick">
        <a href="/?cat=Android">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18c0 .55.45 1 1 1h1v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h2v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h1c.55 0 1-.45 1-1V8H6v10zM3.5 8C2.67 8 2 8.67 2 9.5v7c0 .83.67 1.5 1.5 1.5S5 17.33 5 16.5v-7C5 8.67 4.33 8 3.5 8zm17 0c-.83 0-1.5.67-1.5 1.5v7c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-7c0-.83-.67-1.5-1.5-1.5zm-4.97-5.84l1.3-1.3c.2-.2.2-.51 0-.71-.2-.2-.51-.2-.71 0l-1.48 1.48C14.15 1.23 13.1 1 12 1c-1.1 0-2.15.23-3.09.63L7.43.15c-.2-.2-.51-.2-.71 0-.2.2-.2.51 0 .71l1.3 1.3C6.01 3.23 5 5 5 7h14c0-2-.01-3.77-3.47-4.84zM10 5H9V4h1v1zm5 0h-1V4h1v1z"/></svg>
          Android APK
        </a>
        <a href="/?cat=Windows">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.549H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
          Windows
        </a>
        <a href="/?cat=Games">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M21 6H3a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2zm-10 7H9v2H7v-2H5v-2h2V9h2v2h2v2zm4.5 1c-.83 0-1.5-.67-1.5-1.5S14.67 11 15.5 11s1.5.67 1.5 1.5S16.33 14 15.5 14zm3-3c-.83 0-1.5-.67-1.5-1.5S17.67 8 18.5 8s1.5.67 1.5 1.5S19.33 11 18.5 11z"/></svg>
          Games
        </a>
        <a href="/?cat=Design">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10c1.19 0 2.12-.39 2.7-1.04.56-.63.79-1.48.59-2.33-.08-.34-.08-.73-.01-1.05.27-1.28 1.45-2.54 3.23-2.54h1.5C21.28 15 22 14.28 22 13.5 22 7.7 17.52 2 12 2z"/></svg>
          Design
        </a>
      </div>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-num"><%= total %>+</div>
        <div class="hero-stat-label">SOFTWARE</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">50K+</div>
        <div class="hero-stat-label">WATUMIAJI</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">100%</div>
        <div class="hero-stat-label">BURE</div>
      </div>
    </div>
  </div>
</div>

<!-- MAIN CONTENT full-width -->
<div class="page-wrap">

  <!-- Category filter pills -->
  <div class="filter-bar">
    <a href="/" class="filter-pill <%= currentCat === 'Zote' && !query ? 'active' : '' %>">Zote</a>
    <% categories.forEach(c => { %>
      <a href="/?cat=<%= encodeURIComponent(c.category) %>" class="filter-pill <%= currentCat === c.category ? 'active' : '' %>">
        <%= c.category %>
      </a>
    <% }) %>
    <% if (query) { %>
      <span class="filter-query">
        Matokeo ya "<strong><%= query %></strong>" — <%= total %>
      </span>
    <% } %>
  </div>

  <!-- Section header -->
  <div class="section-head">
    <div class="section-title">
      <%= currentCat !== 'Zote' ? currentCat : 'Software Zote' %>
    </div>
    <% if (totalPages > 1) { %>
      <span class="section-page">Ukurasa <%= currentPage %> / <%= totalPages %></span>
    <% } %>
  </div>

  <!-- App grid 4-column kama LiteAPKs -->
  <% if (apps.length === 0) { %>
    <div class="empty-state">Hakuna software iliyopatikana.</div>
  <% } else { %>
    <div class="app-grid">
      <% apps.forEach(app => {
        const stars = (3 + Math.random() * 2).toFixed(1);
      %> 
      <a href="/app/<%= app.slug %>" class="app-card">
        <div class="app-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm7 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8zm0 2a2 2 0 1 1 0 4 2 2 0 0 1 0-4zm-7 9.5c0-1.5 3.13-2.5 7-2.5s7 1 7 2.5V19H5v-.5z"/></svg>
        </div>
        <div class="app-card-body">
          <div class="app-card-name"><%= app.name %></div>
          <div class="app-card-meta">
            <div class="app-card-rating">
              <span><%= stars %></span>
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            </div>
            <span class="dot">·</span>
            <span class="app-card-cat"><%= app.category %></span>
          </div>
          <div class="app-card-mod">
            <% if (app.is_free) { %>
              <span class="mod-tag green">BURE</span>
            <% } else { %>
              <span class="mod-tag orange">PREMIUM</span>
            <% } %>
            <span class="mod-tag"><%= app.version %></span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  <% } %>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div class="pager">
      <% if (currentPage > 1) { %>
        <a href="/?cat=<%= currentCat %>&q=<%= query %>&page=<%= currentPage - 1 %>" class="page-btn">Iliyopita</a>
      <% } %>
      <% for (let p = Math.max(1, currentPage-2); p <= Math.min(totalPages, currentPage+2); p++) { %>
        <a href="/?cat=<%= currentCat %>&q=<%= query %>&page=<%= p %>" class="page-btn <%= p === currentPage ? 'on' : '' %>"><%= p %></a>
      <% } %>
      <% if (currentPage < totalPages) { %>
        <a href="/?cat=<%= currentCat %>&q=<%= query %>&page=<%= currentPage + 1 %>" class="page-btn">Inayofuata</a>
      <% } %>
    </div>
  <% } %>

</div>

<%- include('partials/footer') %>
<%- include('partials/foot') %>