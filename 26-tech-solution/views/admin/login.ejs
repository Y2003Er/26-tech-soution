<%- include('../partials/head', { title: 'Admin Login — 26 Tech' }) %>

<div class="login-page">
  <div class="login-card">
    <div class="login-title"><span style="color:var(--accent)">26</span>Tech Admin</div>

    <% if (error && error.length > 0) { %>
      <div class="flash error"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login">
      <div class="form-group">
        <label class="form-label">USERNAME</label>
        <input class="form-input" type="text" name="username" autocomplete="username" required/>
      </div>
      <div class="form-group">
        <label class="form-label">PASSWORD</label>
        <input class="form-input" type="password" name="password" autocomplete="current-password" required/>
      </div>
      <button class="btn btn-green" type="submit" style="width:100%;justify-content:center;padding:.65rem;">
        Login
      </button>
    </form>
  </div>
</div>

<%- include('../partials/foot') %>