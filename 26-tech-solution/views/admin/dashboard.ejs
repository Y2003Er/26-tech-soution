<%- include('../partials/head', { title: 'Dashboard - 26 Tech Admin' }) %>
<%- include('../partials/admin-nav') %>

<style>
  /* CSS ya Haraka ya Dashboard ya Kisasa */
  .admin-wrap {
    max-width: 1200px;
    margin: 2rem auto;
    padding: 0 1.5rem;
    font-family: 'Segoe UI', system-ui, sans-serif;
  }
  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding-bottom: 1rem;
    margin-bottom: 2rem;
  }
  .admin-header h1 {
    font-size: 1.8rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
  }
  /* Gridi ya Kadi za Takwimu - Hapa ndipo palipoharibika mwanzo */
  .admin-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .admin-stat-card {
    background: #1e1e24;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 1.25rem;
    text-align: left;
    transition: transform 0.2s;
  }
  .admin-stat-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255,255,255,0.1);
  }
  .admin-stat-val {
    font-size: 2rem;
    font-weight: 700;
    color: #00ff88; /* Rangi ya Tech Green */
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .admin-stat-key {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #8a8a98;
    font-weight: 600;
  }
  /* Vitufe na Flash */
  .btn-modern {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.2rem;
    background: #00ff88;
    color: #0a0a0c;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-modern:hover {
    background: #00dd77;
  }
  .flash {
    padding: 1rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .flash.success {
    background: rgba(0, 255, 136, 0.1);
    border: 1px solid #00ff88;
    color: #00ff88;
  }
  /* Jedwali la Kisasa */
  .table-container {
    background: #1e1e24;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    overflow-x: auto;
    margin-top: 1rem;
  }
  .admin-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    font-size: 0.9rem;
  }
  .admin-table th {
    background: rgba(255,255,255,0.02);
    padding: 1rem;
    color: #8a8a98;
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.5px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .admin-table td {
    padding: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    color: #e2e2e8;
  }
</style>

<div class="admin-wrap">

  <div class="admin-header">
    <h1>Admin Dashboard</h1>
    <div style="display:flex;gap:1rem;align-items:center;">
      <span style="font-size:.85rem;color:#8a8a98">Logged in as <strong style="color:#ffffff"><%= admin.username %></strong></span>
      <form method="POST" action="/admin/logout" style="margin:0;">
        <button class="btn btn-ghost" type="submit" style="cursor:pointer;">Logout</button>
      </form>
    </div>
  </div>

  <% if (success && success.length > 0) { %>
    <div class="flash success"><strong>Safii!</strong> <%= success %></div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="flash error"><%= error %></div>
  <% } %>

  <div class="admin-stats">
    <div class="admin-stat-card">
      <div class="admin-stat-val"><%= stats.total_apps %></div>
      <div class="admin-stat-key">Total Apps</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-val"><%= stats.active_apps %></div>
      <div class="admin-stat-key">Active</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-val"><%= stats.featured_apps %></div>
      <div class="admin-stat-key">Featured</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-val" style="color: #00bfff;"><%= Number(stats.total_downloads || 0).toLocaleString() %></div>
      <div class="admin-stat-key">Downloads</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-val" style="color: #9370db;"><%= Number(stats.total_views || 0).toLocaleString() %></div>
      <div class="admin-stat-key">Views</div>
    </div>
  </div>

  <div style="margin-bottom:1.5rem;">
    <a href="/admin/apps/new" class="btn-modern">+ Add New App</a>
  </div>

  <div class="table-container">
    <table class="admin-table">
      <thead>
        <tr>
          <th>NAME</th>
          <th>CATEGORY</th>
          <th>VERSION</th>
          <th>SIZE</th>
          <th>DOWNLOADS</th>
          <th>STATUS</th>
          <th>ACTIONS</th>
        </tr>
      </thead>
      <tbody>
        <% apps.forEach(app => { %>
        <tr>
          <td>
            <div style="font-weight:600;"><%= app.name %></div>
            <div style="font-size:.75rem;color:#8a8a98"><%= app.slug %></div>
          </td>
          <td><span class="mod-tag"><%= app.category %></span></td>
          <td style="color:#8a8a98;"><%= app.version %></td>
          <td style="color:#8a8a98;"><%= app.file_size %></td>
          <td><%= app.downloads.toLocaleString() %></td>
          <td>
            <% if (app.is_active) { %>
              <span class="mod-tag green" style="background:rgba(0,255,136,0.1); color:#00ff88; padding:2px 6px; border-radius:4px;">Active</span>
            <% } else { %>
              <span class="mod-tag" style="color:#ff4a4a; border:1px solid #ff4a4a; padding:2px 6px; border-radius:4px;">Hidden</span>
            <% } %>
          </td>
          <td>
            <div style="display:flex;gap:.3rem;">
              <a href="/app/<%= app.slug %>" target="_blank" class="btn btn-ghost" style="padding:.25rem .5rem;">View</a>
              <a href="/admin/apps/<%= app.id %>/edit" class="btn btn-blue" style="padding:.25rem .5rem;">Edit</a>
              <form method="POST" action="/admin/apps/<%= app.id %>/delete"
                    onsubmit="return confirm('Delete <%= app.name %>?')" style="margin:0;">
                <button class="btn btn-red" type="submit" style="padding:.25rem .5rem; cursor:pointer;">Del</button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</div>

<div style="text-align: center; padding: 2rem; color: #8a8a98; font-size: 0.85rem; border-top: 1px solid rgba(255, 255, 255, 0.05); margin-top: 3rem;">
  © 2026 26 TECH SOLUTION — ADMIN PANEL
</div>

<%- include('../partials/foot') %>