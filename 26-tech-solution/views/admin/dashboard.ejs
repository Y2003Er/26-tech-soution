<%- include('../partials/head', { title: 'Dashboard - 26 Tech Admin' }) %>
<%- include('../partials/nav') %>

<div class="admin-wrap">

  <div class="admin-header">
    <h1>Admin Dashboard</h1>
    <div style="display:flex;gap:.5rem;align-items:center;">
      <span style="font-size:.75rem;color:var(--dim)">Logged in as <strong style="color:var(--white)"><%= admin.username %></strong></span>
      <form method="POST" action="/admin/logout" style="margin:0;">
        <button class="btn btn-ghost" type="submit">Logout</button>
      </form>
    </div>
  </div>

  <% if (success && success.length > 0) { %><div class="flash success"><%= success %></div><% } %>
  <% if (error && error.length > 0) { %><div class="flash error"><%= error %></div><% } %>

  <div class="admin-stats">
    <div class="admin-stat-card">
      <div class="admin-stat-val"><%= stats.total_apps %></div>
      <div class="admin-stat-key">TOTAL APPS</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-val"><%= stats.active_apps %></div>
      <div class="admin-stat-key">ACTIVE</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-val"><%= stats.featured_apps %></div>
      <div class="admin-stat-key">FEATURED</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-val"><%= Number(stats.total_downloads).toLocaleString() %></div>
      <div class="admin-stat-key">DOWNLOADS</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-val"><%= Number(stats.total_views).toLocaleString() %></div>
      <div class="admin-stat-key">VIEWS</div>
    </div>
  </div>

  <div style="margin-bottom:1rem;">
    <a href="/admin/apps/new" class="btn btn-green">+ Add New App</a>
  </div>

  <div style="background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;">
    <table class="admin-table">
      <thead>
        <tr>
          <th>NAME</th>
          <th>CATEGORY</th>
          <th>VERSION</th>
          <th>SIZE</th>
          <th>DOWNLOADS</th>
          <th>STATUS</th>
          <th>ACTIONS</th>
        </tr>
      </thead>
      <tbody>
        <% apps.forEach(app => { %>
        <tr>
          <td>
            <div style="font-weight:600;font-size:.8rem;"><%= app.name %></div>
            <div style="font-size:.65rem;color:var(--dim)"><%= app.slug %></div>
          </td>
          <td><span class="mod-tag"><%= app.category %></span></td>
          <td style="color:var(--dim);"><%= app.version %></td>
          <td style="color:var(--dim);"><%= app.file_size %></td>
          <td><%= app.downloads.toLocaleString() %></td>
          <td>
            <% if (app.is_active) { %>
              <span class="mod-tag green">Active</span>
            <% } else { %>
              <span class="mod-tag" style="color:var(--red);border-color:var(--red)">Hidden</span>
            <% } %>
            <% if (app.is_featured) { %>
              <span class="mod-tag blue">Featured</span>
            <% } %>
          </td>
          <td>
            <div style="display:flex;gap:.3rem;">
              <a href="/app/<%= app.slug %>" target="_blank" class="btn btn-ghost" style="padding:.25rem .5rem;">View</a>
              <a href="/admin/apps/<%= app.id %>/edit" class="btn btn-blue" style="padding:.25rem .5rem;">Edit</a>
              <form method="POST" action="/admin/apps/<%= app.id %>/delete"
                    onsubmit="return confirm('Delete <%= app.name %>?')" style="margin:0;">
                <button class="btn btn-red" type="submit" style="padding:.25rem .5rem;">Del</button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</div>

<%- include('../partials/footer') %>
<%- include('../partials/foot') %>