<%- include('partials/head', { title: 'Pakua — ' + app.name }) %>
<%- include('partials/nav') %>

<div class="dl-page">
  <div class="dl-box">
    <div class="dl-box-icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
    </div>
    <div class="dl-box-name"><%= app.name %></div>
    <div class="dl-box-sub">
      Subiri sekunde chache. Download itaanza moja kwa moja.<br/>
      Ukubwa: <strong><%= app.file_size %></strong> · Toleo: <strong><%= app.version %></strong>
    </div>

    <div class="timer-ring">
      <svg viewBox="0 0 100 100" width="90" height="90">
        <circle class="timer-circle-bg" cx="50" cy="50" r="45"/>
        <circle class="timer-circle" id="timerCircle" cx="50" cy="50" r="45"/>
      </svg>
      <div class="timer-num" id="timerNum">15</div>
    </div>

    <div class="ad-slot">NAFASI YA TANGAZO</div>

    <a href="<%= app.download_url %>" class="dl-go-btn" id="dlBtn">
      Bonyeza Hapa Kupakua
    </a>
    <div class="dl-note">FAILI SALAMA · HAKUNA VIRUSI · TOLEO KAMILI</div>
  </div>
</div>

<%- include('partials/footer') %>
<%- include('partials/foot') %>