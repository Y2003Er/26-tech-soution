<%- include('partials/head', { title }) %>
<%- include('partials/nav') %>
<div class="l1 light"></div>
<div class="l2 light"></div>

<input type="hidden" id="timer-seconds" value="<%= timerSeconds %>"/>

<div class="dl-page">
  <div class="dl-box">
    <span class="dl-box-icon"><%= app.icon %></span>
    <div class="dl-box-name"><%= app.name %></div>
    <p class="dl-box-sub">
      Subiri kidogo — link yako ya download inaandaliwa.<br/>
      Usifunge ukurasa huu.
    </p>

    <!-- Timer ring -->
    <div class="timer-ring">
      <svg width="100" height="100" viewBox="0 0 100 100">
        <circle class="timer-circle-bg" cx="50" cy="50" r="45"/>
        <circle class="timer-circle" id="timer-circle" cx="50" cy="50" r="45"/>
      </svg>
      <div class="timer-num" id="timer-num"><%= timerSeconds %></div>
    </div>

    <!-- Ad slot placeholder (weka ad yako hapa) -->
    <div style="
      background:rgba(255,255,255,0.03);
      border:1px dashed rgba(255,255,255,0.08);
      border-radius:10px;
      height:90px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-family:var(--f-mono);
      font-size:.6rem;
      letter-spacing:.12em;
      color:var(--dim);
      margin-bottom:1.5rem;
    ">
      [ ADVERTISEMENT ]
    </div>

    <!-- Button inaonekana baada ya timer -->
    <a href="/go/<%= token %>" id="dl-go-btn" class="dl-go-btn">
      ⬇ Pakua Sasa — <%= app.name %>
    </a>

    <div class="dl-note">
      LINK ITAKWISHA BAADA YA DAKIKA <%= process.env.TOKEN_EXPIRY_MINUTES || 15 %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
<script src="/js/timer.js"></script>
<%- include('partials/foot') %>
