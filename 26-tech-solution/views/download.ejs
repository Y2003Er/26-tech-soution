<%- include('partials/head', { title }) %>
<%- include('partials/nav') %>

<input type="hidden" id="timer-seconds" value="<%= timerSeconds %>"/>

<div class="dl-page">
  <div class="dl-box">
    <span class="dl-box-icon"><%= app.icon %></span>
    <div class="dl-box-name"><%= app.name %></div>
    <p class="dl-box-sub">
      Subiri sekunde <%= timerSeconds %> — link yako ya download inaandaliwa.<br/>
      Usifunge ukurasa huu.
    </p>

    <div class="timer-ring">
      <svg width="90" height="90" viewBox="0 0 100 100">
        <circle class="timer-circle-bg" cx="50" cy="50" r="45"/>
        <circle class="timer-circle" id="timer-circle" cx="50" cy="50" r="45"/>
      </svg>
      <div class="timer-num" id="timer-num"><%= timerSeconds %></div>
    </div>

    <!-- Ad slot -->
    <div class="ad-slot">[ ADVERTISEMENT ]</div>

    <a href="/go/<%= token %>" id="dl-go-btn" class="dl-go-btn">
      ⬇ Pakua Sasa — <%= app.name %>
    </a>

    <div class="dl-note">LINK ITAKWISHA DAKIKA <%= process.env.TOKEN_EXPIRY_MINUTES || 15 %></div>
  </div>
</div>

<%- include('partials/footer') %>
<script src="/js/timer.js"></script>
<%- include('partials/foot') %>
